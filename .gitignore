# Playwright (frontend E2E)
# Generated artefacts from src/elspeth/web/frontend Playwright runs.
# - test-results/      per-test traces, videos, screenshots on failure
# - playwright-report/ HTML reporter output
# - .e2e-data/         disposable backend ELSPETH_DATA_DIR (SQLite, blob store)
# - tests/e2e/.auth/   saved storageState (logged-in cookies, JWT) — never commit
src/elspeth/web/frontend/test-results/
src/elspeth/web/frontend/playwright-report/
src/elspeth/web/frontend/.e2e-data/
src/elspeth/web/frontend/tests/e2e/.auth/
src/elspeth/web/frontend/playwright/.cache/

# Secrets - NEVER commit these
.env.local
.env.*.local
secrets/
!src/elspeth/**/secrets/
!tests/**/secrets/
credentials.json
*.pem
*.key

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# Mutation testing
.mutmut-cache
mutants/

# uv
.uv-cache/

# Git worktrees
.worktrees/

# Example outputs (dynamic data, not tracked)
# Use ** to match nested paths (prevents accidental deep-nesting commits)
examples/**/output/*
examples/**/runs/*
examples/**/chroma_data/*
!examples/*/output/
!examples/*/runs/
!examples/*/output/.gitkeep
!examples/*/runs/.gitkeep

# Local test databases and logs
state/

# Local web app data - keep only the placeholder directory marker
data/*
!data/.gitkeep
!data/skills/
!data/skills/.gitignore
!data/skills/*.example

# Real/production/example data - never commit
real/
examples/large_scale_test/input.csv
examples/retention_purge/payloads/
landscape.db-shm
landscape.db-wal
.elspeth/

# pre-commit cache
.pre-commit-cache/

# Tool-specific local config and caches
.codex/

# Filigree issue tracker
.filigree/
.mcp.json

# Deployment artifacts
deploy/

# FINAL RULE: Always keep .gitkeep files (preserve directory structure)
# This must be at the end to override any earlier ignore patterns
!.gitkeep

# Temporary
.codex

# Build-artefact PDFs (regeneratable; exceed the pre-commit
# large-file threshold). Narrow scope to PDF outputs only — the
# `docs/release/pdf/` pipeline source (build.sh, *.typ, README,
# Makefile, etc.) IS tracked so the pipeline is reproducible from
# a fresh checkout.
docs/assets/*.pdf
.claude/scheduled_tasks.lock
*.db-shm
*.db-wal

# Release PDF pipeline source is intentionally tracked; generated
# outputs and bulky font source trees are not.
# No its not - John M. 2024-06-03: The pipeline source is tracked, but the generated PDFs and font source trees are not. This allows us to keep the repository size manageable while still ensuring that the necessary files for reproducing the PDF builds are included.
docs/release/pdf/*
!docs/release/pdf/
!docs/release/pdf/*.typ
!docs/release/pdf/README.md
!docs/release/pdf/Makefile
!docs/release/pdf/build.sh
!docs/release/pdf/versions.lock
!docs/release/pdf/fonts/
docs/release/pdf/fonts/*
!docs/release/pdf/fonts/public-sans/
docs/release/pdf/fonts/public-sans/*
!docs/release/pdf/fonts/public-sans/LICENSE.md
!docs/release/pdf/fonts/public-sans/OFL.txt
!docs/release/pdf/fonts/public-sans/fonts/
docs/release/pdf/fonts/public-sans/fonts/*
!docs/release/pdf/fonts/public-sans/fonts/ttf/
!docs/release/pdf/fonts/public-sans/fonts/ttf/*.ttf
docs/release/pdf/out/
docs/release/pdf/tokens.typ
