# evals/composer-harness/.env.example
#
# Copy to .env in the same directory (or any parent up to evals/) and fill in.
# common.sh will auto-discover the nearest .env on the path upward from the
# script being run, so you can also keep this at evals/.env if you have
# multiple harnesses sharing the same credentials.
#
# DO NOT commit .env. It is gitignored.

# --- Required -----------------------------------------------------------

# Base URL of the ELSPETH web service under test. No trailing slash.
# Examples:
#   ELSPETH_EVAL_BASE_URL=https://elspeth.foundryside.dev      # public staging
#   ELSPETH_EVAL_BASE_URL=http://localhost:8000                # local dev
ELSPETH_EVAL_BASE_URL=

# Login credentials for the evaluation user.
ELSPETH_EVAL_USER=
ELSPETH_EVAL_PASS=

# --- Optional -----------------------------------------------------------

# Where to write per-scenario output. If unset, harness.sh writes to
#   <harness>/runs/<utc-date>-hardmode/<scenario_id>/
# so re-runs across days don't clobber each other.
# ELSPETH_EVAL_RUNS_DIR=

# Run-poll timeout (seconds). The finaliser polls /api/runs/<rid> until the
# status is terminal or this timeout fires. 300s is comfortable for the
# 8-15 row scenarios in this suite; raise for stress scenarios.
# ELSPETH_EVAL_RUN_TIMEOUT_SEC=300

# Poll interval (seconds) between /api/runs/<rid> calls.
# ELSPETH_EVAL_RUN_POLL_INTERVAL=3

# JWT auto-refresh threshold (seconds). If the JWT exp claim is within this
# many seconds of expiry, the harness re-logins before the next call. Default
# is 300 (5 minutes); raise if you have long convergence-timeouts on a
# 1-hour-TTL token.
# ELSPETH_EVAL_JWT_REFRESH_MARGIN_SEC=300

# Per-curl ceiling (seconds). The composer's /messages call has been
# observed taking up to 180s on convergence-timeouts; default 240 leaves
# headroom. Raise only if you hit timeouts that aren't the composer's own
# 180s ceiling.
# ELSPETH_EVAL_CURL_MAX_TIME=240
