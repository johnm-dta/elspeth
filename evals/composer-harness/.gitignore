# Local credentials — never committed.
.env
.env.local

# Per-scenario runs accumulate here. The fixtures + harness scripts are
# the reusable inputs; runs/ contains evidence from specific executions
# and should be committed selectively (e.g. as a dated evidence folder
# alongside a report) rather than en masse.
runs/

# JWTs that may have leaked outside runs/ (defense in depth).
**/jwt*.txt
**/login*.json
