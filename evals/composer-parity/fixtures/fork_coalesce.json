{
  "class": "fork_coalesce",
  "intent": "Read rows from CSV, fan every row into two independent parallel branches, then wait for both branches to complete before merging them back into one row. The merge must require all branches, not select one.",
  "canonical_arguments": {
    "source": {
      "plugin": "csv",
      "on_success": "gate_in",
      "options": {"path": "rows.csv", "schema": {"mode": "observed"}},
      "on_validation_failure": "discard"
    },
    "nodes": [
      {
        "id": "fork_gate",
        "node_type": "gate",
        "input": "gate_in",
        "condition": "True",
        "routes": {"true": "fork", "false": "fork"},
        "fork_to": ["path_a", "path_b"]
      },
      {
        "id": "merge_results",
        "node_type": "coalesce",
        "input": "path_a",
        "branches": {"path_a": "path_a", "path_b": "path_b"},
        "policy": "require_all",
        "merge": "union"
      },
      {
        "id": "finalize",
        "node_type": "transform",
        "plugin": "passthrough",
        "input": "merge_results",
        "on_success": "merged",
        "on_error": "discard",
        "options": {"schema": {"mode": "observed"}}
      }
    ],
    "edges": [
      {"id": "e1", "from_node": "source", "to_node": "fork_gate", "edge_type": "on_success", "label": null},
      {"id": "e2", "from_node": "fork_gate", "to_node": "merge_results", "edge_type": "fork", "label": "path_a"},
      {"id": "e3", "from_node": "fork_gate", "to_node": "merge_results", "edge_type": "fork", "label": "path_b"},
      {"id": "e4", "from_node": "merge_results", "to_node": "finalize", "edge_type": "on_success", "label": null}
    ],
    "outputs": [
      {
        "sink_name": "merged",
        "plugin": "json",
        "options": {"path": "outputs/merged.json", "format": "json", "schema": {"mode": "observed"}, "mode": "write", "collision_policy": "auto_increment"},
        "on_write_failure": "discard"
      }
    ],
    "metadata": {"name": "fork-coalesce", "description": "Fork into two branches, require-all coalesce, flat union merge."}
  },
  "semantic_expectations": {
    "source": {"plugin": "csv", "on_success": "gate_in"},
    "nodes": [
      {"id": "fork_gate", "node_type": "gate", "input": "gate_in", "fork_to": ["path_a", "path_b"]},
      {"id": "merge_results", "node_type": "coalesce", "branches": {"path_a": "path_a", "path_b": "path_b"}, "policy": "require_all", "merge": "union"},
      {"id": "finalize", "node_type": "transform", "plugin": "passthrough", "input": "merge_results", "on_success": "merged"}
    ],
    "edges": [
      {"from_node": "source", "to_node": "fork_gate", "edge_type": "on_success"},
      {"from_node": "fork_gate", "to_node": "merge_results", "edge_type": "fork", "label": "path_a"},
      {"from_node": "fork_gate", "to_node": "merge_results", "edge_type": "fork", "label": "path_b"},
      {"from_node": "merge_results", "to_node": "finalize", "edge_type": "on_success"}
    ],
    "outputs": [{"sink_name": "merged", "plugin": "json"}],
    "topology": "source -> fork_gate(fork path_a,path_b) -> merge_results(coalesce require_all) -> finalize(transform) -> merged(sink)"
  },
  "runtime_assertions": [
    "The fork gate emits every row to two independent branch connections (path_a and path_b).",
    "The coalesce node waits for all branches (policy require_all) before emitting a merged row.",
    "The merge is a flat union of both branches, not a branch selection.",
    "One merged row is produced per original source row."
  ]
}
