{
  "class": "multi_output",
  "intent": "Read records from CSV, pass them through one transform, then write to two distinctly-named outputs with different write-failure policies: a priority JSON output whose write failures fall back to the standard output, and a standard CSV output whose write failures are discarded.",
  "canonical_arguments": {
    "source": {
      "plugin": "csv",
      "on_success": "rows",
      "options": {"path": "records.csv", "schema": {"mode": "observed"}},
      "on_validation_failure": "discard"
    },
    "nodes": [
      {
        "id": "score",
        "node_type": "transform",
        "plugin": "passthrough",
        "input": "rows",
        "on_success": "scored",
        "on_error": "discard",
        "options": {"schema": {"mode": "observed"}}
      },
      {
        "id": "priority_gate",
        "node_type": "gate",
        "input": "scored",
        "condition": "row['priority'] == 'high'",
        "routes": {"true": "priority_out", "false": "standard_out"}
      }
    ],
    "edges": [],
    "outputs": [
      {
        "sink_name": "priority_out",
        "plugin": "json",
        "options": {"path": "outputs/priority.json", "format": "json", "schema": {"mode": "observed"}, "mode": "write", "collision_policy": "auto_increment"},
        "on_write_failure": "standard_out"
      },
      {
        "sink_name": "standard_out",
        "plugin": "csv",
        "options": {"path": "outputs/standard.csv", "schema": {"mode": "observed"}, "mode": "write", "collision_policy": "auto_increment"},
        "on_write_failure": "discard"
      }
    ],
    "metadata": {"name": "multi-output", "description": "Two distinct outputs with distinct write-failure policies."}
  },
  "semantic_expectations": {
    "source": {"plugin": "csv", "on_success": "rows"},
    "nodes": [
      {"id": "score", "node_type": "transform", "plugin": "passthrough", "input": "rows", "on_success": "scored"},
      {"id": "priority_gate", "node_type": "gate", "input": "scored", "routes": {"true": "priority_out", "false": "standard_out"}}
    ],
    "edges": [],
    "outputs": [
      {"sink_name": "priority_out", "plugin": "json", "on_write_failure": "standard_out"},
      {"sink_name": "standard_out", "plugin": "csv", "on_write_failure": "discard"}
    ],
    "topology": "source -> score(transform) -> priority_gate(gate) -> {priority_out(json), standard_out(csv)}"
  },
  "runtime_assertions": [
    "Two distinctly-named output sinks are declared with different plugins (json vs csv).",
    "The two outputs carry different on_write_failure policies: priority_out rejoins to standard_out, standard_out discards.",
    "Both output names are addressable as routing targets and resolve to distinct sinks."
  ]
}
