{
  "knob_schema": {
    "fields": [
      {
        "description": "Schema configuration for data validation. Use 'schema: {mode: observed}' to infer types from data, or provide explicit field definitions with mode (fixed/flexible).",
        "kind": "json-value",
        "label": "Schema",
        "name": "schema",
        "nullable": false,
        "required": true
      },
      {
        "description": "S3 bucket name or access-point identifier",
        "kind": "text",
        "label": "Bucket",
        "name": "bucket",
        "nullable": false,
        "required": true
      },
      {
        "description": "S3 object key",
        "kind": "text",
        "label": "Key",
        "name": "key",
        "nullable": false,
        "required": true
      },
      {
        "default": "csv",
        "description": "S3 object data format",
        "enum": [
          "csv",
          "json",
          "jsonl"
        ],
        "kind": "enum",
        "label": "Format",
        "name": "format",
        "nullable": false,
        "required": false
      },
      {
        "description": "CSV parsing options",
        "kind": "json-object",
        "label": "CSV Options",
        "name": "csv_options",
        "nullable": false,
        "required": false
      },
      {
        "description": "JSON and JSONL parsing options",
        "kind": "json-object",
        "label": "JSON Options",
        "name": "json_options",
        "nullable": false,
        "required": false
      },
      {
        "default": null,
        "description": "Explicit columns for headerless CSV",
        "item_kind": "text",
        "kind": "string-list",
        "label": "Columns",
        "name": "columns",
        "nullable": true,
        "required": false
      },
      {
        "default": null,
        "description": "Overrides for normalized source fields",
        "kind": "json-object",
        "label": "Field Mapping",
        "name": "field_mapping",
        "nullable": true,
        "required": false
      },
      {
        "description": "Quarantine sink name or explicit discard",
        "kind": "text",
        "label": "On Validation Failure",
        "name": "on_validation_failure",
        "nullable": false,
        "required": true
      },
      {
        "default": null,
        "description": "AWS signing region override",
        "kind": "text",
        "label": "Region Name",
        "name": "region_name",
        "nullable": true,
        "required": false
      },
      {
        "default": null,
        "description": "CLI/batch-only S3-compatible HTTP endpoint",
        "kind": "text",
        "label": "Endpoint URL",
        "name": "endpoint_url",
        "nullable": true,
        "required": false
      },
      {
        "default": 268435456,
        "description": "Maximum S3 object bytes accepted",
        "kind": "number-int",
        "label": "Max Object Bytes",
        "name": "max_object_bytes",
        "nullable": false,
        "required": false
      },
      {
        "default": 1000000,
        "description": "Maximum decoded characters in one source record",
        "kind": "number-int",
        "label": "Max Record Chars",
        "name": "max_record_chars",
        "nullable": false,
        "required": false
      }
    ]
  },
  "plugin_kind": "source",
  "plugin_name": "aws_s3"
}
