{
  "knob_schema": {
    "fields": [
      {
        "description": "Schema configuration for data validation. Use 'schema: {mode: observed}' to infer types from data, or provide explicit field definitions with mode (fixed/flexible).",
        "kind": "json-value",
        "label": "schema_config",
        "name": "schema_config",
        "nullable": false,
        "required": true
      },
      {
        "kind": "text",
        "label": "path",
        "name": "path",
        "nullable": false,
        "required": true
      },
      {
        "description": "Sink name for non-conformant rows, or 'discard' for explicit drop",
        "kind": "text",
        "label": "on_validation_failure",
        "name": "on_validation_failure",
        "nullable": false,
        "required": true
      },
      {
        "default": null,
        "item_kind": "text",
        "kind": "string-list",
        "label": "columns",
        "name": "columns",
        "nullable": true,
        "required": false
      },
      {
        "default": null,
        "kind": "json-object",
        "label": "field_mapping",
        "name": "field_mapping",
        "nullable": true,
        "required": false
      },
      {
        "default": ",",
        "kind": "text",
        "label": "delimiter",
        "name": "delimiter",
        "nullable": false,
        "required": false
      },
      {
        "default": "utf-8",
        "kind": "text",
        "label": "encoding",
        "name": "encoding",
        "nullable": false,
        "required": false
      },
      {
        "default": 0,
        "kind": "number-int",
        "label": "skip_rows",
        "name": "skip_rows",
        "nullable": false,
        "required": false
      }
    ]
  },
  "plugin_kind": "source",
  "plugin_name": "csv"
}
