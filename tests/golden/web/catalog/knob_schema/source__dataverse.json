{
  "knob_schema": {
    "fields": [
      {
        "description": "Schema configuration for data validation. Use 'schema: {mode: observed}' to infer types from data, or provide explicit field definitions with mode (fixed/flexible).",
        "kind": "json-value",
        "label": "Schema",
        "name": "schema_config",
        "nullable": false,
        "required": true
      },
      {
        "description": "Dataverse environment URL (e.g., https://myorg.crm.dynamics.com)",
        "kind": "text",
        "label": "Environment URL",
        "name": "environment_url",
        "nullable": false,
        "required": true
      },
      {
        "description": "Authentication configuration",
        "kind": "json-object",
        "label": "Auth",
        "name": "auth",
        "nullable": false,
        "required": true
      },
      {
        "default": "v9.2",
        "description": "Dataverse Web API version",
        "kind": "text",
        "label": "API Version",
        "name": "api_version",
        "nullable": false,
        "required": false
      },
      {
        "description": "Sink name for non-conformant rows, or 'discard' for explicit drop",
        "kind": "text",
        "label": "On Validation Failure",
        "name": "on_validation_failure",
        "nullable": false,
        "required": true
      },
      {
        "default": null,
        "description": "Entity logical name (e.g., 'contact')",
        "kind": "text",
        "label": "Entity",
        "name": "entity",
        "nullable": true,
        "required": false
      },
      {
        "default": null,
        "description": "$select fields (None = all)",
        "item_kind": "text",
        "kind": "string-list",
        "label": "Select",
        "name": "select",
        "nullable": true,
        "required": false
      },
      {
        "default": null,
        "description": "$filter expression (static OData only)",
        "kind": "text",
        "label": "Filter",
        "name": "filter",
        "nullable": true,
        "required": false
      },
      {
        "default": null,
        "description": "$orderby expression",
        "kind": "text",
        "label": "Orderby",
        "name": "orderby",
        "nullable": true,
        "required": false
      },
      {
        "default": null,
        "description": "$top limit (None = all records)",
        "kind": "number-int",
        "label": "Top",
        "name": "top",
        "nullable": true,
        "required": false
      },
      {
        "default": null,
        "description": "Raw FetchXML string",
        "kind": "text",
        "label": "Fetch XML",
        "name": "fetch_xml",
        "nullable": true,
        "required": false
      },
      {
        "default": null,
        "description": "Manual field name overrides",
        "kind": "json-object",
        "label": "Field Mapping",
        "name": "field_mapping",
        "nullable": true,
        "required": false
      },
      {
        "default": false,
        "description": "Preserve Dataverse formatted value annotations",
        "kind": "checkbox",
        "label": "Include Formatted Values",
        "name": "include_formatted_values",
        "nullable": false,
        "required": false
      },
      {
        "default": null,
        "description": "Additional Dataverse domain patterns for SSRF allowlist",
        "item_kind": "text",
        "kind": "string-list",
        "label": "Additional Domains",
        "name": "additional_domains",
        "nullable": true,
        "required": false
      }
    ]
  },
  "plugin_kind": "source",
  "plugin_name": "dataverse"
}
