{
  "knob_schema": {
    "fields": [
      {
        "description": "Schema configuration for data validation. Use 'schema: {mode: observed}' to infer types from data, or provide explicit field definitions with mode (fixed/flexible).",
        "kind": "json-value",
        "label": "schema_config",
        "name": "schema_config",
        "nullable": false,
        "required": true
      },
      {
        "kind": "text",
        "label": "path",
        "name": "path",
        "nullable": false,
        "required": true
      },
      {
        "description": "Sink name for non-conformant rows, or 'discard' for explicit drop",
        "kind": "text",
        "label": "on_validation_failure",
        "name": "on_validation_failure",
        "nullable": false,
        "required": true
      },
      {
        "kind": "text",
        "label": "column",
        "name": "column",
        "nullable": false,
        "required": true
      },
      {
        "default": "utf-8",
        "kind": "text",
        "label": "encoding",
        "name": "encoding",
        "nullable": false,
        "required": false
      },
      {
        "default": true,
        "kind": "checkbox",
        "label": "strip_whitespace",
        "name": "strip_whitespace",
        "nullable": false,
        "required": false
      },
      {
        "default": true,
        "kind": "checkbox",
        "label": "skip_blank_lines",
        "name": "skip_blank_lines",
        "nullable": false,
        "required": false
      }
    ]
  },
  "plugin_kind": "source",
  "plugin_name": "text"
}
